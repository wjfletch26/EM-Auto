# ============================================================
# Deaton Outreach Automation — Environment Configuration
# ============================================================
# Copy to `.env` and adjust. Optional second file:
#   `.env.${APP_ENV}`  e.g. `.env.local`, `.env.production` (overrides `.env`)

# --- Deployment identity (safety + scheduler defaults follow this, not NODE_ENV alone) ---
# local | staging | production    Default if unset: local
APP_ENV=local
# development | production — affects log formatting (e.g. pino-pretty). Optional.
NODE_ENV=development

# --- Google Sheets ---
GOOGLE_SERVICE_ACCOUNT_PATH=./credentials/service-account.json
# Active sheet for this process (test/staging/prod depending on APP_ENV)
GOOGLE_SPREADSHEET_ID=your-test-or-prod-spreadsheet-id
# Real production sheet ID — required everywhere; used to block local/staging from using prod data
PRODUCTION_GOOGLE_SPREADSHEET_ID=your-real-production-spreadsheet-id

# --- Email safety ---
# Simulated send (no SMTP; Sheet may still update as if sent): DRY_RUN=true
# Test recipient (real SMTP only to TEST_RECIPIENT): DRY_RUN=false and set TEST_RECIPIENT
DRY_RUN=true
# TEST_RECIPIENT=safe-test-inbox@example.com
# Production: leave DRY_RUN=false and TEST_RECIPIENT unset

# --- Scheduler (cron). Default: on for production only; off for local/staging ---
# SCHEDULER_ENABLED=true

# --- SAFE_MODE (optional, typically production VPS) ---
# When true: no background cron; Admin API allows GET only (no POST/PATCH). /health and unsubscribe stay up.
# SAFE_MODE=true

# Optional: custom path for deploy-manifest.json (see RUN_AND_DEPLOY.md)
# DEPLOY_MANIFEST_PATH=deploy-manifest.json

# --- SMTP (Microsoft 365) ---
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=dave@deatonengineering.us
SMTP_PASS=your-email-password-here
SMTP_SECURE=false
SMTP_FROM_NAME=Dave at Deaton Engineering
REPLY_FORWARD_TO=dknieriem@deatonengineering.com

# --- IMAP (optional — Tier 3 leaves this false) ---
IMAP_ENABLED=false
IMAP_HOST=outlook.office365.com
IMAP_PORT=993
IMAP_USER=dave@deatonengineering.us
IMAP_PASS=your-email-password-here

# --- Unsubscribe ---
UNSUB_SECRET=generate-this-with-openssl-rand-hex-32-min-32-chars
UNSUB_BASE_URL=https://unsub.deatonengineering.us
UNSUB_EXPIRY_DAYS=90
UNSUB_PORT=3000

# --- Scheduling ---
SEND_CRON=*/5 * * * *
REPLY_CRON=*/5 * * * *
SEND_DELAY_MS=15000
SEND_BATCH_SIZE=10

# --- Logging ---
LOG_LEVEL=info
LOG_DIR=./data/logs
LOG_RETENTION_DAYS=30

# --- CAN-SPAM ---
PHYSICAL_ADDRESS="Deaton Engineering Building, 2 Sierra Way St #110, Georgetown, TX 78626"

# --- Intelligence Pipeline (LLM) ---
PIPELINE_ENABLED=false
PIPELINE_CRON=*/5 * * * *
PERPLEXITY_API_KEY=your-perplexity-api-key-here
PERPLEXITY_MODEL=sonar
LLM_PROVIDER=perplexity
LLM_API_KEY=your-llm-api-key-here
LLM_MODEL=sonar
LLM_BASE_URL=https://api.perplexity.ai

# --- Admin (optional) ---
# ADMIN_API_KEY=
# ADMIN_UI_ENABLED=true
