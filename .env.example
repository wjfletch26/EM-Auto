# ============================================================
# Deaton Outreach Automation — Phase 0 Credentials
# ============================================================
# Copy this file to .env and fill in your real values:
#   cp .env.example .env

# --- SMTP (Microsoft 365) ---
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=dave@deatonengineering.us
SMTP_PASS=your-email-password-here
SMTP_FROM_NAME=Dave at Deaton Engineering

# --- IMAP (for reply processing test) ---
IMAP_HOST=outlook.office365.com
IMAP_PORT=993
IMAP_USER=dave@deatonengineering.us
IMAP_PASS=your-email-password-here

# --- Test recipient (where the test email gets sent) ---
TEST_RECIPIENT=dave@deatonengineering.us
