# ============================================================
# Production overrides — merged after root `.env` when APP_ENV=production
# (see src/config/index.ts). Set APP_ENV=production in your base `.env` on
# the server (or export it before start) so this file is loaded.
# ============================================================
#
# NEVER commit real passwords or API keys here if this file is in git —
# use your secrets store / server-only copy.
#
# Production rule: GOOGLE_SPREADSHEET_ID must equal PRODUCTION_GOOGLE_SPREADSHEET_ID.

#APP_ENV=production
#NODE_ENV=production

# Same ID for both — required by the config schema in production.
#GOOGLE_SPREADSHEET_ID=your-real-production-spreadsheet-id
#PRODUCTION_GOOGLE_SPREADSHEET_ID=your-real-production-spreadsheet-id

#GOOGLE_SERVICE_ACCOUNT_PATH=./credentials/service-account.json

#DRY_RUN=false
# TEST_RECIPIENT must be unset in production (omit or leave commented).

# Live send — set real SMTP (and IMAP if you enable Tier 3).
#SMTP_HOST=smtp.office365.com
#SMTP_PORT=587
#SMTP_USER=your-production-sender@example.com
#SMTP_PASS=your-production-email-password
#SMTP_SECURE=false
#SMTP_FROM_NAME=Deaton Engineering
#REPLY_FORWARD_TO=your-ops-inbox@example.com

#IMAP_ENABLED=false
#IMAP_HOST=outlook.office365.com
#IMAP_PORT=993
#IMAP_USER=your-production-sender@example.com
#IMAP_PASS=your-production-email-password

#UNSUB_SECRET=replace-with-openssl-rand-hex-32-min-32-chars
#UNSUB_BASE_URL=https://unsub.deatonengineering.us
#UNSUB_EXPIRY_DAYS=90
#UNSUB_PORT=3000

# Cron is on by default when APP_ENV=production unless you override SCHEDULER_ENABLED.
#SCHEDULER_ENABLED=true
#SEND_CRON=*/5 * * * *
#REPLY_CRON=*/5 * * * *
#SEND_DELAY_MS=15000
#SEND_BATCH_SIZE=10

#LOG_LEVEL=info
#LOG_DIR=./data/logs
#LOG_RETENTION_DAYS=30

#PHYSICAL_ADDRESS="Deaton Engineering Building, 2 Sierra Way St #110, Georgetown, TX 78626"

# Intelligence pipeline — set real keys on the server when enabled.
#PIPELINE_ENABLED=false
#PIPELINE_CRON=*/5 * * * *
#PERPLEXITY_API_KEY=
#PERPLEXITY_MODEL=sonar
#LLM_PROVIDER=perplexity
#LLM_API_KEY=
#LLM_MODEL=sonar
#LLM_BASE_URL=https://api.perplexity.ai

# Dashboard / admin — set strong secrets in production.
# DASHBOARD_SECRET=
# ADMIN_API_KEY=
# ADMIN_UI_ENABLED=true
