# ============================================================
# Test environment — loaded first by `test-env-bootstrap.mjs` when you run
# `npm test` (override: true so accidental root `.env` values do not win).
#
# Safe to commit: placeholders only. Copy to tweak locally; CI does not require
# this file because the bootstrap still fills missing vars.
# ============================================================

APP_ENV=local
NODE_ENV=development

# Must differ — non-production cannot use the canonical production sheet ID.
PRODUCTION_GOOGLE_SPREADSHEET_ID=__test_prod_sheet_canonical__
GOOGLE_SPREADSHEET_ID=__test_local_sheet__

GOOGLE_SERVICE_ACCOUNT_PATH=./credentials/service-account.json

DRY_RUN=true

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=sender@example.com
SMTP_PASS=test-smtp-pass-not-used-in-unit-tests
SMTP_SECURE=false
SMTP_FROM_NAME=Test Sender
REPLY_FORWARD_TO=review@example.com

IMAP_ENABLED=false
IMAP_HOST=outlook.office365.com
IMAP_PORT=993

UNSUB_SECRET=00000000000000000000000000000000
UNSUB_BASE_URL=https://unsub.example.com
UNSUB_EXPIRY_DAYS=90
UNSUB_PORT=3000

SCHEDULER_ENABLED=false
PIPELINE_ENABLED=false

LOG_LEVEL=info
LOG_DIR=./data/logs
LOG_RETENTION_DAYS=30

PHYSICAL_ADDRESS=123 Test St, Test City, TX 00000, USA
